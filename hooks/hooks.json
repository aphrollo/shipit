{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/skills/router/SKILL.md\" 2>/dev/null || echo 'shipit router not found'",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'SHIPIT: Work request? Classify → dispatch per /router. Question? Respond normally. Telegram active? Report each phase.'",
            "async": false
          }
        ]
      }
    ]
  }
}
